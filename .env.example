# Local Ollama Configuration (Free 100%)
# Ensure Ollama is running on your host: https://ollama.com/
# Use 'host.docker.internal' to reach your host from inside Docker on macOS/Windows.
OLLAMA_API_URL=http://host.docker.internal:11434/v1/chat/completions
OLLAMA_MODEL=deepseek-r1:8b

# AI Sentiment Service (Python)
AI_SERVICE_URL=http://ai-service:8000

# Server port
PORT=8080
